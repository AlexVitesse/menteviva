# Build de produccion: el backend uvicorn sirve el dist/ desde el mismo origen,
# asi que VITE_API_URL y VITE_WS_URL quedan VACIOS -> el frontend usa URLs
# relativas (fetch("/api/...") y new WebSocket("wss://<host>/api/...")).
#
# Si el deploy estuviera split en dos hosts (frontend en CDN, backend separado)
# habria que setear ambos aqui. Para el piloto (un solo proceso behind Cloudflare
# Tunnel) las dejamos vacias.
VITE_API_URL=
VITE_WS_URL=

# Firebase Web SDK — mismo proyecto que dev, no hay separado por ahora.

# Dejar VACIOS para que el frontend use URLs relativas y vite/proxy los rutee.
# Esto hace que funcione tanto en localhost como detras de un tunnel HTTPS
# (ngrok, devtunnels, etc) sin reconfigurar.
#
# Solo override si necesitas apuntar a un backend remoto especifico.
VITE_API_URL=
VITE_WS_URL=

# ============================================================
# Firebase Web SDK (para auth)
# ============================================================
# Ver FIREBASE_SETUP.md para sacar estos valores. Son la "config web"
# del proyecto Firebase: Project Settings > General > Your apps > Web app.
# Si dejas todos vacios, la pagina de login mostrara un error y la auth
# queda deshabilitada (resto del frontend sigue compilando).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

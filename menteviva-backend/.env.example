# Groq API Keys (obtener en https://console.groq.com)
# Soporta hasta 4 keys para rotación y evitar rate limits
# Con 4 keys puedes soportar ~20 usuarios concurrentes
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_4=gsk_xxxxxxxxxxxxxxxxxxxxx

# ElevenLabs (TTS para los avatares)
ELEVENLABS_API_KEY=

# Debug mode
DEBUG=true

# CORS Origins (separados por coma si son multiples)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============================================================
# Firebase Admin SDK (para verificar ID tokens del frontend)
# ============================================================
# Usa UNA de las dos opciones, no ambas.
#
# Opcion A — ruta a un service account JSON (recomendado en local).
# Descargar de Firebase Console > Project Settings > Service accounts >
# Generate new private key. Guardarlo fuera del repo (o en .gitignore)
# y poner aqui la ruta absoluta o relativa al working dir del backend.
FIREBASE_SERVICE_ACCOUNT_PATH=

# Opcion B — el JSON inline (recomendado en hosts tipo Render donde no
# subes archivos). Pegar el contenido completo del JSON, en una sola linea
# y con comillas escapadas. Si esta opcion esta seteada, ignora la A.
FIREBASE_SERVICE_ACCOUNT_JSON=
